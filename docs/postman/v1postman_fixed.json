{
	"info": {
		"_postman_id": "laptop-repair-api-v1",
		"name": "Laptop Repair Store API v1 - FIXED",
		"description": "Complete API collection with role-based authentication. All endpoints require proper authentication.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Collection-level: Auto-fetch IDs if not set",
					"var token = pm.collectionVariables.get('access_token');",
					"var baseUrl = pm.collectionVariables.get('base_url');",
					"",
					"if (token && baseUrl) {",
					"    // Auto-fetch device_type_id",
					"    if (!pm.collectionVariables.get('device_type_id')) {",
					"        pm.sendRequest({",
					"            url: baseUrl + '/v1/devices/types',",
					"            method: 'GET',",
					"            header: { 'Authorization': 'Bearer ' + token }",
					"        }, function (err, res) {",
					"            if (!err && res.code === 200) {",
					"                var types = res.json();",
					"                if (types && types.length > 0) {",
					"                    pm.collectionVariables.set('device_type_id', types[0].id);",
					"                }",
					"            }",
					"        });",
					"    }",
					"    ",
					"    // Auto-fetch brand_id",
					"    if (!pm.collectionVariables.get('brand_id')) {",
					"        pm.sendRequest({",
					"            url: baseUrl + '/v1/devices/brands',",
					"            method: 'GET',",
					"            header: { 'Authorization': 'Bearer ' + token }",
					"        }, function (err, res) {",
					"            if (!err && res.code === 200) {",
					"                var brands = res.json();",
					"                if (brands && brands.length > 0) {",
					"                    pm.collectionVariables.set('brand_id', brands[0].id);",
					"                }",
					"            }",
					"        });",
					"    }",
					"    ",
					"    // Auto-fetch model_id",
					"    if (!pm.collectionVariables.get('model_id')) {",
					"        pm.sendRequest({",
					"            url: baseUrl + '/v1/devices/models',",
					"            method: 'GET',",
					"            header: { 'Authorization': 'Bearer ' + token }",
					"        }, function (err, res) {",
					"            if (!err && res.code === 200) {",
					"                var models = res.json();",
					"                if (models && models.length > 0) {",
					"                    pm.collectionVariables.set('model_id', models[0].id);",
					"                }",
					"            }",
					"        });",
					"    }",
					"    ",
					"    // Auto-fetch device_id",
					"    if (!pm.collectionVariables.get('device_id')) {",
					"        pm.sendRequest({",
					"            url: baseUrl + '/v1/devices?limit=1',",
					"            method: 'GET',",
					"            header: { 'Authorization': 'Bearer ' + token }",
					"        }, function (err, res) {",
					"            if (!err && res.code === 200) {",
					"                var devices = res.json();",
					"                if (devices && devices.length > 0) {",
					"                    pm.collectionVariables.set('device_id', devices[0].id);",
					"                }",
					"            }",
					"        });",
					"    }",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has user data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('full_name');",
									"    pm.expect(jsonData).to.have.property('phone');",
									"    pm.collectionVariables.set('user_id', jsonData.id);",
									"});",
									"",
									"pm.test(\"Response has role field\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('role');",
									"    // New users should have null role",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"full_name\": \"Test User\",\n    \"phone\": \"{{$randomPhoneNumber}}\",\n    \"email\": \"test{{$randomInt}}@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
