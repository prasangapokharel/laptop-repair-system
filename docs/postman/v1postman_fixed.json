				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has tokens\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('tokens');",
									"    pm.expect(jsonData.tokens).to.have.property('access_token');",
									"    pm.expect(jsonData.tokens).to.have.property('refresh_token');",
									"    pm.collectionVariables.set('access_token', jsonData.tokens.access_token);",
									"    pm.collectionVariables.set('refresh_token', jsonData.tokens.refresh_token);",
									"    pm.collectionVariables.set('user_id', jsonData.user.id);",
									"});",
									"",
									"pm.test(\"Response has user with role\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('user');",
									"    pm.expect(jsonData.user).to.have.property('role');",
									"    ",
									"    // If user has a role, validate role structure",
									"    if (jsonData.user.role) {",
									"        pm.expect(jsonData.user.role).to.have.property('id');",
									"        pm.expect(jsonData.user.role).to.have.property('name');",
									"        pm.expect(jsonData.user.role).to.have.property('description');",
									"        pm.expect(jsonData.user.role).to.have.property('created_at');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
