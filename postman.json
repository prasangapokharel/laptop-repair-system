{
  "info": {
    "name": "Laptop Repair Store - Complete API Collection v2",
    "description": "Complete API collection for Laptop Repair Store Management System with all endpoints including Technician features. Updated January 2026.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
