              "host": ["{{BASE_URL}}"],
              "path": ["orders", "1", "history"]
            },
            "description": "View complete status change history for an order"
          }
        },
        {
          "name": "6️⃣ Submit Cost Estimate",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cost\": 5000.00,\n  \"discount\": 500.00,\n  \"note\": \"Screen replacement required. Estimated completion in 3 days.\",\n  \"estimated_completion_date\": \"2026-01-10T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/orders/1",
              "host": ["{{BASE_URL}}"],
              "path": ["orders", "1"]
            },
            "description": "Technician submits cost estimate for customer approval (Pending status)"
          }
        },
        {
          "name": "7️⃣ Start Repair - Update to Repairing",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Repairing\",\n  \"note\": \"Customer approved. Starting repair work.\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/orders/1",
              "host": ["{{BASE_URL}}"],
              "path": ["orders", "1"]
            },
            "description": "Update order status to Repairing after customer approval"
          }
        },
        {
          "name": "8️⃣ Update Repair Progress",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Screen removed. Installing new screen. 60% complete.\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/orders/1",
              "host": ["{{BASE_URL}}"],
              "path": ["orders", "1"]
            },
            "description": "Update repair progress notes"
          }
        },
        {
          "name": "9️⃣ Complete Repair",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Completed\",\n  \"note\": \"Repair completed successfully. Screen replaced and tested. All functions working.\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/orders/1",
              "host": ["{{BASE_URL}}"],
              "path": ["orders", "1"]
            },
            "description": "Mark repair as completed (Repairing -> Completed)"
          }
        },
        {
